---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { langs, getTranslations } from '../../../i18n'

export async function getStaticPaths() {
  const paths = []
  for (const lang of langs) {
    const posts = await getCollection('blog', (p) => p.id.endsWith(`/${lang}`))
    paths.push({ params: { lang }, props: { posts, lang } })
  }
  return paths
}

const { posts, lang } = Astro.props
const t = await getTranslations(lang)
---

<BaseLayout title={t.blogPosts} lang={lang}>
  <h1 class="text-3xl font-bold mb-8">{t.blogPosts}</h1>
  <div class="space-y-8">
    {posts.map((post) => (
      <a href={`/${lang}/blog/${post.id.replace(`/${lang}`, '')}`} class="block group rounded-xl overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
        {post.data.image && (
          <Image src={post.data.image} alt={post.data.title} class="w-full h-52 object-cover" />
        )}
        <div class="p-5">
          <h2 class="text-xl font-semibold group-hover:text-blue-600">{post.data.title}</h2>
          {post.data.description && <p class="text-gray-500 mt-1">{post.data.description}</p>}
          <time class="text-sm text-gray-400 mt-2 block">{post.data.date.toLocaleDateString()}</time>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
