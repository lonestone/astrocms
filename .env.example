# CMS Server
ASTROCMS_PASSWORD=

# Git
GIT_REPO_URL=https://github.com/user/repo
GIT_BRANCH=main
GIT_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GIT_USER_EMAIL=cms@astrocms.dev
GIT_USER_NAME=AstroCMS

# Overrides for astrocms.json fields (leave empty to keep the JSON value)
ASTROCMS_CONTENT_DIR=
ASTROCMS_CONTENT_CONFIG=
ASTROCMS_ASSETS_DIR=
ASTROCMS_COMPONENTS_DIR=

# Optional website dev server (Docker)
# When set, the container runs this command and astrocms proxies its root
# path to the dev server on ASTROCMS_DEV_PORT. The CMS lives under /astrocms.
ASTROCMS_DEV_CMD=
ASTROCMS_DEV_PORT=
