# CMS Server
ASTROCMS_PASSWORD=1234

# Git
GIT_REPO_URL=https://github.com/withastro/astro.build
GIT_BRANCH=main
GIT_PAT=
GIT_USER_EMAIL=cms@astrocms.dev
GIT_USER_NAME=AstroCMS

# Overrides for astrocms.json fields (leave empty to keep the JSON value)
ASTROCMS_CONTENT_DIR=src/content
ASTROCMS_CONTENT_CONFIG=src/content.config.ts
ASTROCMS_ASSETS_DIR=src/assets
ASTROCMS_COMPONENTS_DIR=src/components

# Optional website dev server (Docker)
# When set, the container runs this command and astrocms proxies its root
# path to the dev server on ASTROCMS_DEV_PORT. The CMS lives under /astrocms.
ASTROCMS_DEV_CMD=npm run dev
#ASTROCMS_DEV_PORT=4321

# Optional install command override (Docker). By default the entrypoint
# auto-detects npm / pnpm / yarn / bun from the lockfile.
#ASTROCMS_INSTALL_CMD=
