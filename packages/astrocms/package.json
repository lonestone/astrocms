{
  "name": "astrocms",
  "version": "0.1.1",
  "description": "A headless CMS for Astro with a built-in AI agent for editing content.",
  "type": "module",
  "license": "MIT",
  "author": "Godefroy de Compreignac",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lonestone/astrocms.git"
  },
  "homepage": "https://github.com/lonestone/astrocms#readme",
  "bugs": {
    "url": "https://github.com/lonestone/astrocms/issues"
  },
  "keywords": [
    "astro",
    "cms",
    "headless-cms",
    "content-management",
    "ai",
    "agent",
    "markdown",
    "mdx"
  ],
  "bin": {
    "astrocms": "bin/astrocms.js"
  },
  "files": [
    "backend",
    "dist",
    "bin",
    "patches"
  ],
  "scripts": {
    "dev": "tsx watch backend/server.ts & vite dev --config frontend/vite.config.ts",
    "dev:server": "tsx watch backend/server.ts",
    "dev:frontend": "vite dev --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "prepack": "cp ../../README.md ./README.md",
    "postpack": "rm -f ./README.md"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.20",
    "@assistant-ui/react-ai-sdk": "^1.3.15",
    "@hono/node-server": "^1.19.11",
    "@mdxeditor/editor": "^3.55.0",
    "@tanstack/react-query": "^5.91.2",
    "@types/diff": "^7.0.2",
    "ai": "^6.0.138",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "cm6-graphql": "^0.2.1",
    "country-flag-icons": "^1.6.15",
    "diff": "^8.0.4",
    "dotenv": "^16.6.1",
    "hono": "^4.12.8",
    "jiti": "^2.4.2",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router": "^7.13.1",
    "smol-toml": "^1.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "yaml": "^2.8.2",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1"
  }
}
